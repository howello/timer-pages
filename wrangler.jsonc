{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "timer",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "common",
      "database_id": "d7e31a71-e897-4e17-92fb-394b4c73ae3f"
    }
  ],
  "observability": {
    "enabled": true
  }
}
